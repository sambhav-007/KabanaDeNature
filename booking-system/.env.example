# ── Server ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development          # set to "production" on the server / Vercel
SESSION_SECRET=change-me-to-a-long-random-string   # used to sign the admin auth cookie

# Where "Back to site" on the booking page should go.
# All-in-one (site + booking served together): leave as "/".
SITE_URL=/

# ── Database (MongoDB Atlas) ───────────────────────────
# Atlas free tier: https://www.mongodb.com/cloud/atlas — create an M0 cluster,
# a database user, allow network access, and copy the connection string.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=kabana

# ── Admin login ────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# ── Booking behaviour ──────────────────────────────────
CURRENCY=INR
HOLD_MINUTES=15            # how long a pending (unpaid) booking holds inventory

# ── Razorpay ───────────────────────────────────────────
# Leave BOTH blank to run in MOCK PAYMENT MODE. Fill with TEST keys to test payments,
# LIVE keys for production. From https://dashboard.razorpay.com (Settings > API Keys).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Inventory provider ─────────────────────────────────
# mongo (default) = our database is the source of truth.
# cm   = delegate availability + booking push to a channel-manager API (implement CMInventoryProvider).
INVENTORY_PROVIDER=mongo
CM_API_BASE=
CM_API_KEY=
